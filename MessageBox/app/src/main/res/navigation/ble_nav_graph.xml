            android:id="@+id/action_main_fragment_to_main_location_fragment"
            app:destination="@id/main_location_fragment" />
        <action
            android:id="@+id/action_main_fragment_to_main_setting_parent_fragment"
            app:destination="@id/main_setting_parent_fragment" />
    </fragment>

    <fragment
        android:id="@+id/main_ble_set_fragment"
        android:name="com.ah.acr.messagebox.BleItemFragment"
        android:label="BLE"
        tools:layout="@layout/fragment_ble_item">
        <action
