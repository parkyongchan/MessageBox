            app:destination="@id/main_ble_login_fragment" />
        <action
            android:id="@+id/action_main_ble_set_fragment_to_main_ble_login_change_fragment"
            app:destination="@id/main_ble_login_change_fragment" />
    </fragment>

    <fragment
        android:id="@+id/main_ble_login_fragment"
        android:name="com.ah.acr.messagebox.BleLoginFragment"
        android:label="Ble Login"
        tools:layout="@layout/fragment_ble_login">
        <action
            android:id="@+id/action_main_ble_login_fragment_to_main_ble_set_fragment"
            app:destination="@id/main_ble_set_fragment"/>
        <action
            android:id="@+id/action_main_ble_login_fragment_to_main_fragment"
            app:destination="@id/main_fragment" />
    </fragment>

    <fragment
        android:id="@+id/main_ble_login_change_fragment"
        android:name="com.ah.acr.messagebox.BleLoginChangeFragment"
        android:label="Ble Password Change"
        tools:layout="@layout/fragment_ble_login_change">

    </fragment>




    <fragment
        android:id="@+id/main_status_fragment"
        android:name="com.ah.acr.messagebox.StatusFragment"
        android:label="Status"
        tools:layout="@layout/fragment_status">
        <action
            android:id="@+id/action_main_status_fragment_to_main_map_fragment"
            app:destination="@id/main_map_fragment" />
    </fragment>


    <fragment
        android:id="@+id/main_setting_parent_fragment"
        android:name="com.ah.acr.messagebox.SettingParentFragment"
        android:label="Setting"
        tools:layout="@layout/fragment_setting_parent">
        <action
            android:id="@+id/action_main_setting_fragment_to_main_ble_login_change_fragment"
            app:destination="@id/main_ble_login_change_fragment" />
    </fragment>

