<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    tools:context=".MsgOutBoxSubNewFragment">

    <!-- 타이틀 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1F3C"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/text_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Message"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 스크롤 가능한 입력 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Receiver 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Receiver"
                android:textColor="#95B0D4"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <!-- Receiver 입력 + 검색 버튼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_card"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/text_receiver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Enter number or nickname"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A7090"
                    android:textSize="14sp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp" />

                <ImageButton
                    android:id="@+id/button_search"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_search"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Title 라벨 + 바이트 카운터 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Title (optional)"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/text_title_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/20"
                    android:textColor="#5A7090"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Title 입력 -->
            <EditText
                android:id="@+id/text_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_card"
                android:hint="Enter title (max 20 bytes)"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A7090"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- Message 라벨 + 바이트 카운터 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Message"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/text_msg_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/200"
                    android:textColor="#5A7090"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Message 입력 -->
            <EditText
                android:id="@+id/text_message"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@drawable/bg_input_card"
                android:hint="Enter message (max 200 bytes)"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A7090"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:scrollHorizontally="false"
                android:maxLines="16" />

        </LinearLayout>

    </ScrollView>

    <!-- 하단 고정 버튼 영역 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A2F50" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:padding="12dp">

        <Button
            android:id="@+id/button_msg_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Cancel"
            android:textColor="#95B0D4"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_cancel"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/button_msg_save"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.5"
            android:layout_marginStart="6dp"
            android:text="Queue"
            android:textColor="#0A1628"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_primary"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</LinearLayout>