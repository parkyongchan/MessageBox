<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MsgOutBoxSubNewFragment">


    <LinearLayout
        android:layout_width="373dp"
        android:layout_height="639dp"
        android:layout_gravity="center"
        android:layout_margin="10dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_subject"
                android:layout_width="232dp"
                android:layout_height="wrap_content"
                android:text="@string/outbox_sub_subject1"
                android:textAlignment="center"
                android:textSize="40sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="79dp"
                android:layout_height="wrap_content"
                android:text="@string/outbox_sub_receiver"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/text_receiver"
                android:layout_width="284dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/livt_view_boder"
                android:paddingRight="15dp"
                android:textAlignment="center"
                android:textSize="20sp" />

            <Button
                android:id="@+id/button_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="search"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="79dp"
                android:layout_height="wrap_content"
                android:text="@string/outbox_sub_title"
                android:textSize="20sp" />

            <EditText
                android:id="@+id/text_title"
                android:layout_width="284dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/livt_view_boder"
                android:paddingRight="15dp"
                android:textAlignment="center"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/text_title_size"
                android:layout_width="77dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0/20"
                android:textAlignment="center"
                android:textSize="20sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="269dp"
                android:layout_height="wrap_content"
                android:text="@string/outbox_sub_content"
                android:textSize="20sp" />

            <!--            <Spinner-->
            <!--                android:id="@+id/spinner_msg_type"-->
            <!--                android:layout_width="108dp"-->
            <!--                android:layout_height="match_parent"-->
            <!--                android:layout_weight="1"-->
            <!--                android:text=""-->
            <!--                android:textSize="20sp" />-->
            <TextView
                android:id="@+id/text_msg_size"
                android:layout_width="77dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0/200"
                android:textAlignment="center"
                android:textSize="20sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="348dp"
            android:layout_marginTop="0dp"
            android:background="@drawable/livt_view_boder"
            android:gravity="center|fill_vertical"
            android:orientation="vertical">

            <EditText
                android:id="@+id/text_message"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="top|left"
                android:inputType="textMultiLine"
                android:lines="16"
                android:maxLength="240"
                android:maxLines="16"
                android:minLines="1"
                android:scrollbars="vertical"
                android:scrollHorizontally="false"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_msg_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:layout_weight="1"
                android:text="@string/outbox_sub_cancel"
                android:textSize="20sp" />

            <Button
                android:id="@+id/button_msg_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:layout_weight="1"
                android:text="@string/outbox_sub_save"
                android:textSize="20sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>