<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    android:orientation="vertical">


    <!-- Segmented Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_segment_container"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/segMyLocation"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_segment_button"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:text="📱 My Location"
            android:textColor="#0A1628"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/segSatellite"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_segment_button"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:text="🛰 Satellite TRACK"
            android:textColor="#95B0D4"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Tab 1: My Location -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/containerMyLocation"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">


        <!-- State: Not Tracking -->
        <LinearLayout
            android:id="@+id/stateNotTracking"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="visible">

            <!-- Settings Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_track_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙ Track Settings"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Interval"
                            android:textColor="#95B0D4"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/spinnerInterval"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:background="@drawable/bg_spinner"
                            android:minHeight="36dp"
                            android:padding="6dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Min Distance"
                            android:textColor="#95B0D4"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/spinnerDistance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:background="@drawable/bg_spinner"
                            android:minHeight="36dp"
                            android:padding="6dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>


            <Button
                android:id="@+id/btnStartTracking"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_track_start"
                android:text="🔴  Start Tracking"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Saved Tracks"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTrackCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="24dp"
                android:text="No saved tracks yet.\nTap &quot;Start Tracking&quot; above!"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="13sp"
                android:visibility="visible" />

        </LinearLayout>


        <!-- State: Tracking -->
        <LinearLayout
            android:id="@+id/stateTracking"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_track_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvElapsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="monospace"
                    android:text="00:00:00"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 km"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:text="·"
                    android:textColor="#95B0D4" />

                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 km/h"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:text="·"
                    android:textColor="#95B0D4" />

                <TextView
                    android:id="@+id/tvPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pt"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapViewTracking"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tvWaitingGps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="#CC000000"
                    android:padding="12dp"
                    android:text="🛰 Waiting for GPS..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </FrameLayout>


            <Button
                android:id="@+id/btnStopTracking"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_track_start"
                android:text="⏹  Stop &amp; Save"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>


    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Tab 2: Satellite TRACK -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/containerSatellite"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">


        <!-- State: Not Tracking -->
        <LinearLayout
            android:id="@+id/satStateNotTracking"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_track_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛰 Satellite TRACK Mode"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Starts TRACK mode on the connected TYTO device.\nGPS points received via satellite will be recorded to this session."
                    android:textColor="#95B0D4"
                    android:textSize="12sp" />

                <!-- ⭐ NEW: Clickable Settings Link -->
                <LinearLayout
                    android:id="@+id/linkSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_link"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Runs with settings from Location Report tab"
                        android:textColor="#FFB300"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#FFB300"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connected device:"
                        android:textColor="#95B0D4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvSatConnectedImei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="-"
                        android:textColor="#FF5252"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>


            <Button
                android:id="@+id/btnSatStart"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_track_start"
                android:text="🔴  Start TRACK"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Saved Satellite Tracks"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSatTrackCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSatTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptySatTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="24dp"
                android:text="No saved satellite tracks yet.\nConnect BLE device and tap &quot;Start TRACK&quot;."
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="13sp"
                android:visibility="visible" />

        </LinearLayout>


        <!-- State: Tracking -->
        <LinearLayout
            android:id="@+id/satStateTracking"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_track_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛰"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvSatElapsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="monospace"
                    android:text="00:00:00"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvSatDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 km"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:text="·"
                    android:textColor="#95B0D4" />

                <TextView
                    android:id="@+id/tvSatPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pt"
                    android:textColor="#00E5D1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapViewSatTracking"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tvSatWaitingGps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="#CC000000"
                    android:padding="12dp"
                    android:text="🛰 Waiting for satellite GPS..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </FrameLayout>


            <Button
                android:id="@+id/btnSatStop"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_track_start"
                android:text="⏹  Stop &amp; Save"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
