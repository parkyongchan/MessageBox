<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    tools:context=".LocationFragment">

    <!-- ═══════ HEADER ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_pin"
            app:tint="#00E5D1"
            android:layout_marginEnd="8dp"
            android:contentDescription="Location" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RECEIVED DATA LIST"
            android:textColor="#00E5D1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <ImageButton
            android:id="@+id/button_reflesh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_refresh"
            app:tint="#95B0D4"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Refresh" />

    </LinearLayout>

    <!-- ═══════ 필터 영역 ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1F3C"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- 날짜 범위 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 시작일 -->
            <LinearLayout
                android:id="@+id/btn_start_date"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_card"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Start date" />

                <TextView
                    android:id="@+id/tv_start_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026-04-11"
                    android:textColor="#E8F1FB"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- 종료일 -->
            <LinearLayout
                android:id="@+id/btn_end_date"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_card"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="End date" />

                <TextView
                    android:id="@+id/tv_end_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026-04-18"
                    android:textColor="#E8F1FB"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <!-- Quick 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/chip_1h"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="1h"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_24h"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="24h"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_3d"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_7d"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="7d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_30d"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="30d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 검색 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_card"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                app:tint="#5A7090"
                android:layout_marginEnd="8dp"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/edit_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Search IMEI or Alias..."
                android:textColor="#FFFFFF"
                android:textColorHint="#5A7090"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:imeOptions="actionSearch"
                android:inputType="text" />

        </LinearLayout>

        <!-- 타입 필터 (All / Track / SOS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="All"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_track"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Track"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/chip_sos"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SOS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════ 장비 목록 섹션 헤더 ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_contacts"
            app:tint="#95B0D4"
            android:layout_marginEnd="6dp"
            android:contentDescription="Devices" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DEVICES"
            android:textColor="#95B0D4"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#00E5D1"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ═══════ 장비 목록 ═══════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_location"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- 빈 상태 -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_pin"
            app:tint="#2A4570"
            android:contentDescription="No data" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No location data"
            android:textColor="#5A7090"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adjust filters or wait for new data"
            android:textColor="#4A5F78"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ═══════ 지도 영역 (Phase 3) ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0D1F3C"
        android:gravity="center">

        <FrameLayout
            android:id="@+id/map_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Placeholder (Phase 3에서 제거) -->
            <LinearLayout
                android:id="@+id/map_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_tab_location"
                    app:tint="#2A4570"
                    android:contentDescription="Map" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Map area"
                    android:textColor="#5A7090"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Will be loaded with OSMDroid + MBTiles)"
                    android:textColor="#4A5F78"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- ═══════ 지도 상태 바 ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A1628"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- AUTOPLAY -->
        <LinearLayout
            android:id="@+id/status_autoplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/dot_autoplay"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#4A5F78"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUTOPLAY"
                android:textColor="#5A7090"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_autoplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#95B0D4"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Separator -->
        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:background="#2A4570"
            android:layout_marginEnd="12dp" />

        <!-- SAT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAT"
                android:textColor="#5A7090"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IRIDIUM"
                android:textColor="#00E5D1"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Separator -->
        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:background="#2A4570"
            android:layout_marginEnd="12dp" />

        <!-- DATUM -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATUM"
                android:textColor="#5A7090"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WGS84"
                android:textColor="#95B0D4"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- POINTS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POINTS"
                android:textColor="#5A7090"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#00E5D1"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>