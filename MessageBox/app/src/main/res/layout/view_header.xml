<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/header_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0A1628"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- ⭐ 새 TYTO Connect 로고 (Signal Node) -->
    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/logo_tyto_connect"
        android:contentDescription="TYTO Connect Logo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/text_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYTO Connect"
            android:textColor="#E8F1FB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_header_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IMEI  -"
            android:textColor="#95B0D4"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace" />

    </LinearLayout>


    <!-- ⭐ TRACK 버튼 (신규) -->
    <FrameLayout
        android:id="@+id/btn_track_header"
        android:layout_width="44dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_track_button"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_marginEnd="6dp">

        <TextView
            android:id="@+id/text_track_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/header_track"
            android:textColor="#00E5D1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

    </FrameLayout>


    <!-- SOS 버튼 (기존) -->
    <FrameLayout
        android:id="@+id/btn_sos_header"
        android:layout_width="44dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_sos_button"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:layout_marginEnd="6dp">

        <TextView
            android:id="@+id/text_sos_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOS"
            android:textColor="#E24B4A"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

    </FrameLayout>


    <!-- ⭐ 종료 버튼 (신규) -->
    <FrameLayout
        android:id="@+id/btn_exit_header"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_exit_button"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_power"
            android:layout_gravity="center"
            app:tint="#95B0D4"
            android:contentDescription="@string/header_exit_desc" />

    </FrameLayout>

</LinearLayout>
