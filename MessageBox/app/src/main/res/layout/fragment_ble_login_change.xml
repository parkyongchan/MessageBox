<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    tools:context=".BleLoginChangeFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <!-- 아이콘 -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@mipmap/ic_blue_remote"
                android:layout_marginBottom="16dp"
                android:contentDescription="BLE icon" />

            <!-- 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Password"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- 안내 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create a new password for TYTO2"
                android:textColor="#95B0D4"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- 안내 박스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_info_box"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="!"
                    android:textColor="#FFB300"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password must be exactly 9 digits (numbers only)"
                    android:textColor="#E8C078"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- IMEI 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMEI"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textAllCaps="true" />

                <EditText
                    android:id="@+id/text_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:background="@android:color/transparent"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textColorHint="#5A7090"
                    android:hint="-"
                    android:fontFamily="monospace"
                    android:padding="0dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 새 비밀번호 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Password"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textAllCaps="true" />

                <EditText
                    android:id="@+id/text_pw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter 9-digit number password"
                    android:inputType="numberPassword"
                    android:maxLength="9"
                    android:digits="0123456789"
                    android:background="@android:color/transparent"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textColorHint="#5A7090"
                    android:padding="0dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 비밀번호 확인 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_card"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textAllCaps="true" />

                <EditText
                    android:id="@+id/text_pw_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Re-enter 9-digit password"
                    android:inputType="numberPassword"
                    android:maxLength="9"
                    android:digits="0123456789"
                    android:background="@android:color/transparent"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textColorHint="#5A7090"
                    android:padding="0dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 변경 버튼 -->
            <Button
                android:id="@+id/button_login"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Save Password"
                android:textColor="#0A1628"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_primary"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>