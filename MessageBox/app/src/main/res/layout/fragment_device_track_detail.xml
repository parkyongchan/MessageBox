<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- ═══════ 헤더 ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tyto_logo"
            app:tint="#00E5D1"
            android:contentDescription="TYTO" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYTO"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginStart="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messenger"
            android:textColor="#00E5D1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="10dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="18dp"
            android:background="#2A4570"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tv_track_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TRACK - 000000000000000"
            android:textColor="#95B0D4"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="middle" />

        <LinearLayout
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_btn_close"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_close"
                app:tint="#FF5252"
                android:layout_marginEnd="4dp"
                android:contentDescription="Close" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════ 기간 + 재생 컨트롤 ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1F3C"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_24h"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="24h"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/chip_48h"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="48h"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/chip_3d"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/chip_7d"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="7d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/chip_30d"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="30d"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:textColor="@color/filter_chip_text_color"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/btn_start_date"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_card"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Start" />

                <TextView
                    android:id="@+id/tv_start_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026-04-11"
                    android:textColor="#E8F1FB"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="#5A7090"
                android:textSize="11sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <LinearLayout
                android:id="@+id/btn_end_date"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_card"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="5dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="End" />

                <TextView
                    android:id="@+id/tv_end_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026-04-18"
                    android:textColor="#E8F1FB"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <TextView
                android:id="@+id/btn_apply"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Apply"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#00E5D1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_btn_play"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_rewind"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_rewind"
                app:tint="#95B0D4"
                android:background="@drawable/bg_btn_control"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:layout_marginEnd="3dp"
                android:contentDescription="Rewind" />

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_previous"
                app:tint="#95B0D4"
                android:background="@drawable/bg_btn_control"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:layout_marginEnd="3dp"
                android:contentDescription="Previous" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:src="@drawable/ic_play"
                app:tint="#00E5D1"
                android:background="@drawable/bg_btn_play"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:layout_marginEnd="3dp"
                android:contentDescription="Play" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_next"
                app:tint="#95B0D4"
                android:background="@drawable/bg_btn_control"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:layout_marginEnd="3dp"
                android:contentDescription="Next" />

            <LinearLayout
                android:id="@+id/btn_speed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_btn_control"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_speed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1x"
                    android:textColor="#E8F1FB"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textColor="#95B0D4"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#00E5D1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════ 트랙 리스트 헤더 (컴팩트) ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A1628"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TRACK LIST"
            android:textColor="#00E5D1"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tv_total_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#00E5D1"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" pts"
            android:textColor="#5A7090"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 컬럼 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="#5A7090"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="TYPE"
            android:textColor="#5A7090"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:text="LAT"
            android:textColor="#5A7090"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:text="LON"
            android:textColor="#5A7090"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TIME"
            android:textColor="#5A7090"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <!-- ═══════ 트랙 리스트 (노랑) - 축소: 27 ⭐ ═══════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="27">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list_tracks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0A1628"
            android:clipToPadding="false"
            android:scrollbars="vertical"
            android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
            android:scrollbarTrackVertical="@drawable/scrollbar_track"
            android:scrollbarStyle="insideOverlay"
            android:scrollbarFadeDuration="0"
            android:scrollbarDefaultDelayBeforeFade="0"
            android:scrollbarSize="5dp" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_pin"
                app:tint="#2A4570"
                android:contentDescription="No data" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No track points"
                android:textColor="#5A7090"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ═══════ 지도 (보라) - 확대: 113 ⭐ ═══════ -->
    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="113"
        android:background="#0D1F3C">

        <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC0A1628"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_margin="8dp"
            android:layout_gravity="top|start">

            <TextView
                android:id="@+id/tv_map_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONLINE"
                android:textColor="#00E5D1"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tv_map_zoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZOOM 10"
                android:textColor="#95B0D4"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="right|center_vertical"
            android:layout_marginEnd="10dp">

            <ImageButton
                android:id="@+id/btn_zoom_in"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_zoom_in"
                app:tint="#FFFFFF"
                android:background="@drawable/bg_map_button"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:layout_marginBottom="6dp"
                android:contentDescription="Zoom in" />

            <ImageButton
                android:id="@+id/btn_zoom_out"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_zoom_out"
                app:tint="#FFFFFF"
                android:background="@drawable/bg_map_button"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="Zoom out" />

            <ImageButton
                android:id="@+id/btn_fit_all"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_fit_all"
                app:tint="#00E5D1"
                android:background="@drawable/bg_map_button"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="Fit all markers" />

        </LinearLayout>

        <!-- ═══════ 정보 박스 ═══════ -->
        <LinearLayout
            android:id="@+id/info_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_info_box"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- SPEED (숨김 가능) -->
            <LinearLayout
                android:id="@+id/info_speed_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textColor="#5A7090"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tv_info_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#E8F1FB"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km/h"
                        android:textColor="#95B0D4"
                        android:textSize="9sp"
                        android:layout_marginStart="2dp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- SPEED와 HEADING 사이 구분선 -->
            <View
                android:id="@+id/info_divider_1"
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#2A4570"
                android:layout_marginEnd="14dp" />

            <!-- HEADING (숨김 가능) -->
            <LinearLayout
                android:id="@+id/info_heading_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEADING"
                    android:textColor="#5A7090"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tv_info_heading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#E8F1FB"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°"
                        android:textColor="#95B0D4"
                        android:textSize="14sp"
                        android:layout_marginStart="1dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- HEADING과 TYPE 사이 구분선 -->
            <View
                android:id="@+id/info_divider_2"
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#2A4570"
                android:layout_marginEnd="14dp" />

            <!-- TYPE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TYPE"
                    android:textColor="#5A7090"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_info_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA"
                    android:textColor="#00E5D1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- TYPE와 TIME 사이 구분선 -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#2A4570"
                android:layout_marginEnd="14dp" />

            <!-- TIME -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
