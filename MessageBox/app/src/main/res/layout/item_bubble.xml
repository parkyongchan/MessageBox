<?xml version="1.0" encoding="utf-8"?>
<!--
  KakaoTalk-style chat bubble layout
  - Sent: right-aligned, yellow bubble
  - Received: left-aligned, white bubble + avatar + name
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_bubble_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:gravity="start">

    <!-- Other party avatar (only shown for received) -->
    <FrameLayout
        android:id="@+id/layout_bubble_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="18dp">

        <ImageView
            android:id="@+id/img_bubble_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar" />

        <TextView
            android:id="@+id/text_bubble_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1A2F50"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Bubble container (sender name + time + bubble row) -->
    <LinearLayout
        android:id="@+id/layout_bubble_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Sender name (only shown for received) -->
        <TextView
            android:id="@+id/text_bubble_sender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#95B0D4"
            android:textSize="12sp"
            android:layout_marginBottom="3dp"
            android:layout_marginStart="4dp" />

        <!-- Time + bubble Row -->
        <LinearLayout
            android:id="@+id/layout_bubble_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <!-- Sent - left side: hourglass + time -->
            <LinearLayout
                android:id="@+id/layout_bubble_time_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <!-- Hourglass icon (pending indicator) -->
                <ImageView
                    android:id="@+id/img_bubble_pending_left"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_pending"
                    android:layout_marginBottom="2dp"
                    android:visibility="gone"
                    android:contentDescription="Pending" />

                <!-- Time -->
                <TextView
                    android:id="@+id/text_bubble_time_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7A8FA8"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Bubble box (KakaoTalk style) -->
            <LinearLayout
                android:id="@+id/layout_bubble_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:maxWidth="260dp"
                android:background="@drawable/bg_bubble_receive">

                <!-- Title -->
                <TextView
                    android:id="@+id/text_bubble_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#0066CC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <!-- Body -->
                <TextView
                    android:id="@+id/text_bubble_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- Received - right side: time only -->
            <TextView
                android:id="@+id/text_bubble_time_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7A8FA8"
                android:textSize="10sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
