<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- ⭐ 헤더 아바타 - FrameLayout + ImageView + TextView fallback -->
        <FrameLayout
            android:id="@+id/frame_chat_room_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp">

            <!-- 아바타 이미지 (AvatarHelper Bitmap 또는 업로드 이미지) -->
            <ImageView
                android:id="@+id/img_chat_room_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Avatar" />

            <!-- Fallback TextView (AvatarHelper 실패 시만 표시) -->
            <TextView
                android:id="@+id/text_chat_room_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#1A2F50"
                android:visibility="gone" />

            <!-- 카메라 편집 힌트 (우측 하단) -->
            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:background="#0D1F3C" />

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_camera"
                app:tint="#00E5D1"
                android:contentDescription="Edit avatar" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_chat_room_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_chat_room_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8899AA"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- 전체삭제 버튼 (휴지통 아이콘) -->
        <ImageView
            android:id="@+id/btn_chat_delete_all"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete_all"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Delete all" />

    </LinearLayout>

    <!-- 말풍선 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_chat_room"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A2F50" />

    <!-- 입력창 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1F3C"
        android:padding="10dp">

        <!-- 제목 입력 -->
        <EditText
            android:id="@+id/edit_chat_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Title (max 20 bytes)"
            android:textColor="#FFFFFF"
            android:textColorHint="#4A5F78"
            android:textSize="12sp"
            android:background="#1A2F50"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="6dp"
            android:singleLine="true" />

        <!-- 본문 + 전송 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edit_chat_msg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter message (max 200 bytes)"
                android:textColor="#FFFFFF"
                android:textColorHint="#4A5F78"
                android:textSize="13sp"
                android:background="#1A2F50"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_chat_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textColor="#0A1628"
                android:textSize="16sp"
                android:backgroundTint="#00E5D1"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
