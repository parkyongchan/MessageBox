<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    tools:context=".SettingFragment">

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_tab_location"
            app:tint="#00E5D1"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/setting_location_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- ═══════ SEND TO ═══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_person"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/setting_receiver_desc" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_send_to"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_receiver_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/text_receiver_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text_receiver_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_receiver_default_label"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_receiver_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_receiver_default_sub"
                        android:textColor="#5A7090"
                        android:textSize="11sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textColor="#5A7090"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- 호환 -->
            <EditText
                android:id="@+id/text_receiver"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/button_search"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:src="@drawable/ic_search"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/setting_search_desc" />

            <!-- ═══════ TRACKING MODE ═══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_mode_car"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/setting_mode_desc" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_tracking_mode"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_card"
                android:gravity="center_vertical"
                android:paddingStart="0dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp">

                <Spinner
                    android:id="@+id/spinner_unit_type"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:popupBackground="@drawable/bg_spinner_popup"
                    android:backgroundTint="#8899AA" />

            </LinearLayout>

            <!-- OR 안내 박스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_or_info"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/setting_or_info"
                    android:textColor="#B3F0EA"
                    android:textSize="11sp"
                    android:lineSpacingExtra="1dp" />

            </LinearLayout>

            <!-- ═══════ TIME INTERVAL ═══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_clock"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/setting_time_desc" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/setting_time_interval"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <CheckBox
                    android:id="@+id/chk_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_enable"
                    android:textColor="#E8F1FB"
                    android:textSize="12sp"
                    android:buttonTint="#00E5D1"
                    android:paddingStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_time_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_card"
                android:padding="10dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/preset_time_3"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="3m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_time_5"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="5m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_time_10"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="10m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_time_15"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="15m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_time_30"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="30m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_time_60"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="60m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <EditText
                        android:id="@+id/text_time"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="3"
                        android:textColor="#00E5D1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:inputType="number"
                        android:maxLength="4"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:minWidth="60dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_minutes"
                        android:textColor="#95B0D4"
                        android:textSize="13sp"
                        android:layout_marginStart="6dp"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_time"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:min="3"
                    android:max="120"
                    android:progress="3" />

            </LinearLayout>

            <!-- ═══════ DISTANCE ═══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_distance"
                    app:tint="#95B0D4"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/setting_distance_desc" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/setting_distance"
                    android:textColor="#95B0D4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <CheckBox
                    android:id="@+id/chk_dist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_enable"
                    android:textColor="#E8F1FB"
                    android:textSize="12sp"
                    android:buttonTint="#00E5D1"
                    android:paddingStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_dist_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_card"
                android:padding="10dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/preset_dist_2"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="20m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_dist_5"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="50m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_dist_10"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="100m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_dist_50"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="500m"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_dist_100"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="1km"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/preset_dist_200"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="2km"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_preset_button"
                        android:textColor="@color/preset_button_text_color"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="3dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <EditText
                        android:id="@+id/text_dist"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="10"
                        android:textColor="#00E5D1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:inputType="number"
                        android:maxLength="4"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:minWidth="60dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_distance_unit"
                        android:textColor="#95B0D4"
                        android:textSize="13sp"
                        android:layout_marginStart="6dp"
                        android:layout_gravity="center_vertical" />

                    <TextView
                        android:id="@+id/text_dist_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(100m)"
                        android:textColor="#5A7090"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_dist"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:min="2"
                    android:max="500"
                    android:progress="10" />

            </LinearLayout>

            <!-- ═══════ SAVE 버튼 ═══════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#00E5D1"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/button_set_save"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_save"
                        app:tint="#0A1628"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@string/setting_save_desc" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_save_button"
                        android:textColor="#0A1628"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ⭐ NEW: START/STOP 사용 안내 박스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_or_info"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <!-- 1줄: Settings의 의미 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/setting_track_buttons_info"
                        android:textColor="#B3F0EA"
                        android:textSize="11sp"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

                <!-- 2줄: 헤더 안내 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#00E5D1"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/setting_track_header_hint"
                        android:textColor="#00E5D1"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════ START / STOP (유지) ═══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#00E5D1"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:id="@+id/button_set_start"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_play"
                            app:tint="#0A1628"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="@string/setting_start_desc" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_start_button"
                            android:textColor="#0A1628"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textAllCaps="false" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#15FF5252"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:id="@+id/button_set_stop"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_btn_stop">

                        <ImageView
                            android:layout_width="16dp"
