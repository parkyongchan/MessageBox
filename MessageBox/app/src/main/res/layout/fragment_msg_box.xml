<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Message Box"
            android:textColor="#00E5D1"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Select 버튼 -->
        <Button
            android:id="@+id/button_select_mode"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="72dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Select"
            android:textColor="#B8CEE8"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_header"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="6dp" />

        <!-- New 버튼 -->
        <Button
            android:id="@+id/button_msg_new"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="72dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="New"
            android:textColor="#00E5D1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_header_accent"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="6dp" />

        <!-- Delete 버튼 (체크모드일 때만 표시) -->
        <Button
            android:id="@+id/button_check_delete"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="72dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Delete"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_header_danger"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- 새로고침 버튼 -->
        <ImageButton
            android:id="@+id/button_reflesh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_refresh"
            android:background="@drawable/bg_btn_header"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Refresh" />

    </LinearLayout>

    <!-- ⭐ Send pending messages 버튼 (CardView로 확실하게) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        app:cardBackgroundColor="#00E5D1"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:id="@+id/button_msg_send"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- 아이콘 (명시적으로 tint 지정) -->
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_send_cloud"
                app:tint="#0A1628"
                android:layout_marginEnd="12dp"
                android:contentDescription="Send" />

            <!-- 텍스트 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send pending messages"
                android:textColor="#0A1628"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0.02" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 전송 진행바 -->
    <ProgressBar
        android:id="@+id/progress_send_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="#00E5D1"
        android:visibility="gone" />

    <!-- 메시지 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_msgbox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- 미전송 메시지 현황 -->
    <LinearLayout
        android:id="@+id/layout_unsent_info"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0D1628"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_pending"
            android:layout_marginEnd="6dp"
            android:contentDescription="Pending" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#8899AA"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/text_unsent_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFB300"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="items"
            android:textColor="#8899AA"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto-dismissed after sending"
            android:textColor="#4A5F78"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 하단 페이저 -->
    <LinearLayout
        android:id="@+id/layout_pager"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#0D1F3C"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_page_first"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="◀◀"
            android:textSize="10sp"
            android:textColor="#8899AA"
            android:background="@drawable/bg_btn_header"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_page_prev"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="◀"
            android:textSize="12sp"
            android:textColor="#8899AA"
            android:background="@drawable/bg_btn_header"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/text_page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textColor="#00E5D1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_page_next"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="▶"
            android:textSize="12sp"
            android:textColor="#8899AA"
            android:background="@drawable/bg_btn_header"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_page_last"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="▶▶"
            android:textSize="10sp"
            android:textColor="#8899AA"
            android:background="@drawable/bg_btn_header"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>