<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D1F3C"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💬 메시지함"
            android:textColor="#00E5D1"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_msg_new"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="✏️ 작성"
            android:textColor="#00E5D1"
            android:textSize="12sp"
            android:backgroundTint="#1A2F50"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/button_reflesh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🔄"
            android:textSize="14sp"
            android:backgroundTint="#1A2F50"
            android:padding="0dp" />

    </LinearLayout>

    <!-- 전송 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A1628"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/button_msg_send"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="📤 미전송 메시지 전송"
            android:textColor="#0A1628"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#00E5D1" />

    </LinearLayout>

    <!-- 전송 진행바 -->
    <ProgressBar
        android:id="@+id/progress_send_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="#00E5D1"
        android:visibility="gone" />

    <!-- 메시지 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_msgbox"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

</LinearLayout>