<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    tools:context=".AddrssBookFragment">

    <!-- ═══════════════════════════════════════════ -->
    <!--   MY PROFILE 섹션                           -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- 섹션 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_person"
                app:tint="#95B0D4"
                android:layout_marginEnd="6dp"
                android:contentDescription="Profile" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY PROFILE"
                android:textColor="#95B0D4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- My Profile 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#152A4A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <!-- ⭐ 내 아바타 박스 (이미지 편집) -->
                <FrameLayout
                    android:id="@+id/frame_my_avatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_avatar_box"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:id="@+id/img_my_avatar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="#5A7090"
                        android:contentDescription="My avatar" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:src="@drawable/ic_camera"
                        app:tint="#00E5D1"
                        android:contentDescription="Edit avatar" />

                </FrameLayout>

                <!-- 이름 + IMEI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/text_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Name"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#8899AA"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Edit 버튼 -->
                <Button
                    android:id="@+id/button_edit"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="60dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Edit"
                    android:textColor="#00E5D1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_btn_header_accent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="6dp" />

                <!-- ⭐ 🔑 Password 변경 버튼 (신규!) -->
                <ImageButton
                    android:id="@+id/button_password"
                    android:layout_width="40dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_lock"
                    app:tint="#00E5D1"
                    android:background="@drawable/bg_btn_header_accent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:contentDescription="Change password" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!--   CONTACTS 섹션                             -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_contacts"
            app:tint="#95B0D4"
            android:layout_marginEnd="6dp"
            android:contentDescription="Contacts" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONTACTS"
            android:textColor="#95B0D4"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <!-- New 버튼 -->
        <Button
            android:id="@+id/button_addr_new"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="64dp"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:text="+  New"
            android:textColor="#00E5D1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_header_accent"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <!-- 연락처 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_address"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
