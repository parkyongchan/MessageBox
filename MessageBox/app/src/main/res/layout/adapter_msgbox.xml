<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="#152A4A"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- 아바타 아이콘 -->
        <ImageView
            android:id="@+id/image_received"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_received"
            android:contentDescription="Receive icon"
            android:layout_marginEnd="12dp" />

        <!-- 이름 + 코드 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_code_num"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="code"
                android:textColor="#8899AA"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Title + Time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end|center_vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Title"
                android:textColor="#B8CEE8"
                android:textColorHint="#4A5F78"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:gravity="end" />

            <TextView
                android:id="@+id/text_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textSize="11sp"
                android:textColor="#4A5F78"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- 삭제 버튼 (아이콘) -->
        <ImageButton
            android:id="@+id/button_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete_all"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Delete" />

    </LinearLayout>

</androidx.cardview.widget.CardView>