<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- 임시 안내 문구 - Step 2에서 하단 탭 + Map 화면으로 교체 예정 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗺"
            android:textSize="48sp"
            android:alpha="0.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="탭 컨텐츠 영역"
            android:textColor="#4A5F78"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 2에서 하단 탭이 추가됩니다"
            android:textColor="#2E4560"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- 숨김 처리된 기존 ID들 (MainFragment.java 참조 유지용) -->
    <TextView
        android:id="@+id/badge_inbox"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_ble_set"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_msg_box"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_location"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_setting"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

</FrameLayout>