<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Temporary placeholder - will be replaced with bottom tabs + Map screen in Step 2 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗺"
            android:textSize="48sp"
            android:alpha="0.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tab content area"
            android:textColor="#4A5F78"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bottom tabs will be added in Step 2"
            android:textColor="#2E4560"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Hidden existing IDs (kept for MainFragment.java reference) -->
    <TextView
        android:id="@+id/badge_inbox"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_ble_set"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_msg_box"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_location"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <View
        android:id="@+id/button_setting"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

</FrameLayout>
