<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A1628"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- 1줄: 타이틀 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛰 TYTO MessageBox"
                android:textColor="#00E5D1"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 2줄: BLE상태 + 위성감도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <!-- BLE 연결 상태 -->
            <TextView
                android:id="@+id/text_ble_status_main"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 미연결"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <!-- 위성감도 라벨 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="위성감도"
                android:textColor="#4A5F78"
                android:textSize="10sp"
                android:layout_marginEnd="4dp" />

            <!-- 신호 감도 막대 (0~5단계) -->
            <LinearLayout
                android:id="@+id/signal_bar_container"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_vertical">

                <!-- 감도 0일때 빨간 X -->
                <TextView
                    android:id="@+id/sig_no_signal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#FF5252"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="3dp"
                    android:visibility="gone" />

                <View
                    android:id="@+id/sig_bar1"
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginEnd="2dp"
                    android:background="#1A2F50" />
                <View
                    android:id="@+id/sig_bar2"
                    android:layout_width="4dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="2dp"
                    android:background="#1A2F50" />
                <View
                    android:id="@+id/sig_bar3"
                    android:layout_width="4dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="2dp"
                    android:background="#1A2F50" />
                <View
                    android:id="@+id/sig_bar4"
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="2dp"
                    android:background="#1A2F50" />
                <View
                    android:id="@+id/sig_bar5"
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#1A2F50" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="72dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ① 상태 카드 (배터리 / 수신 / 대기) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center">

                    <!-- 배터리 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#1A2F50"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔋"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/text_main_battery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="- %"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="배터리"
                            android:textColor="#8899AA"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- 수신 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#1A2F50"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📨"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/text_main_inbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00E5D1"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수신함"
                            android:textColor="#8899AA"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- 대기 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#1A2F50"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📤"
                            android:textSize="22sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/text_main_outbox"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FF5252"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_main_unsent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#FFB300"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginStart="3dp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="송신대기"
                            android:textColor="#8899AA"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ② 위치 상태 카드 (위치보고OFF / TRACKING중 / SOS작동중) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_location_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/text_location_status_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="📍"
                        android:textSize="22sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="위치 상태"
                            android:textColor="#8899AA"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/text_location_status_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="위치보고 OFF"
                            android:textColor="#8899AA"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- 상태 표시 점 -->
                    <View
                        android:id="@+id/dot_location_status"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_gray" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ③ 블루투스 연결 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/button_ble_set"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="📡"
                        android:textSize="20sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="블루투스 연결"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TYTO2 디바이스 스캔 및 연결"
                            android:textColor="#8899AA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#00E5D1"
                        android:textSize="20sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ④ 메시지함 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/button_msg_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="💬"
                        android:textSize="20sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="메시지함"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="위성 메시지 송수신"
                            android:textColor="#8899AA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/badge_inbox"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:background="#FF5252"
                        android:visibility="gone"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#00E5D1"
                        android:textSize="20sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ⑤ 위치 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/button_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="📍"
                        android:textSize="20sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="위치"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS 위치 추적 및 이력"
                            android:textColor="#8899AA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#00E5D1"
                        android:textSize="20sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ⑥ 설정 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/button_setting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#0D1F3C"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="⚙️"
                        android:textSize="20sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="설정"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주소록, 위치보고, SOS 설정"
                            android:textColor="#8899AA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#00E5D1"
                        android:textSize="20sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ⑦ SOS 긴급 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/button_sos_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#3D0000"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🆘"
                        android:textSize="20sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOS 긴급"
                            android:textColor="#FF5252"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="긴급 위치 신호 전송"
                            android:textColor="#8899AA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#FF5252"
                        android:textSize="20sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ⑧ 디바이스 정보 (하단) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="#07101F"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IMEI"
                            android:textColor="#4A5F78"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/text_main_imei"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#6B8AA0"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="모델"
                            android:textColor="#4A5F78"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/text_main_model"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TYTO2"
                            android:textColor="#6B8AA0"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>