<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StatusFragment">

    <LinearLayout
        android:layout_width="348dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="10dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

<!--        <Button-->
<!--            android:id="@+id/button_refresh"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:text="@string/status_refresh" />-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="235dp"
                android:layout_height="wrap_content"
                android:text="@string/status_battery"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/text_status_battery"
                android:focusable="false"
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:textSize="26sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="237dp"
                android:layout_height="wrap_content"
                android:text="@string/status_inbox"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/text_status_inbox"
                android:focusable="false"
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:textSize="26sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="237dp"
                android:layout_height="wrap_content"
                android:text="@string/status_outbox"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/text_status_outbox"
                android:focusable="false"
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:textSize="26sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="238dp"
                android:layout_height="wrap_content"
                android:text="@string/status_signal"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/text_status_signal"
                android:focusable="false"
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:textSize="26sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:text="IMEI"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/text_status_imei"
                android:focusable="false"
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_weight="1"
                android:textSize="24sp" />

        </LinearLayout>



        <View
            android:layout_width="0dp"
            android:layout_height="40dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="left"
            android:background="@drawable/dialog_background"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="238dp"
                    android:layout_height="wrap_content"
                    android:text="@string/status_gps"
                    android:layout_marginStart="10dp"
                    android:textSize="26sp" />
                <Button
                    android:id="@+id/btn_location_view"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:layout_weight="1"
                    android:focusable="false"
                    android:text="map" />
            </LinearLayout>

            <EditText
                android:id="@+id/text_status_gps_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:layout_marginStart="50dp"
                android:text="   Time: "
                android:textSize="20sp" />

            <EditText
                android:id="@+id/text_status_gps_dd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="50dp"
                android:text="   DD: "
                android:textSize="20sp" />

            <EditText
                android:id="@+id/text_status_gps_mgrs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="50dp"
                android:text="   MGRS: "
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_location_copy"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:layout_weight="1"
                    android:focusable="false"
                    android:text="Copy" />
                <View
                    android:layout_width="100dp"
                    android:layout_height="10dp"/>

                <Button
                    android:id="@+id/btn_location_send"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:layout_weight="1"
                    android:focusable="false"
                    android:text="send" />

            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_run_track"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/dialog_background"
                android:text="Tracking"
                android:textSize="26sp" />
            <TextView
                android:id="@+id/text_run_sos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/dialog_background"
                android:layout_marginLeft="40dp"
                android:text="SOS"
                android:textSize="26sp" />

        </LinearLayout>


    </LinearLayout>

</FrameLayout>