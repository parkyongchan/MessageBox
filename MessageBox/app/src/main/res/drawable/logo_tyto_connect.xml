<?xml version="1.0" encoding="utf-8"?>
<!-- TYTO Connect Logo - Signal Node (Optimized for small sizes)
     Usage: res/drawable/logo_tyto_connect.xml
     
     Optimized for:
       - Header (28dp-32dp) ⭐ MAIN USE
       - Status icons
       - Any context where visibility at small sizes matters
     
     Design: Cleaner, bolder for small size readability
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="28"
    android:viewportHeight="28">

    <!-- Outer signal wave (subtle) -->
    <path
        android:pathData="M14,14 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0"
        android:strokeColor="#00E5D1"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.25" />

    <!-- Middle signal wave -->
    <path
        android:pathData="M14,14 m-8.5,0 a8.5,8.5 0 1,0 17,0 a8.5,8.5 0 1,0 -17,0"
        android:strokeColor="#00E5D1"
        android:strokeWidth="1"
        android:strokeAlpha="0.5" />

    <!-- Inner signal wave -->
    <path
        android:pathData="M14,14 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"
        android:strokeColor="#00E5D1"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.8" />

    <!-- Center node (outer) - solid -->
    <path
        android:pathData="M14,14 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
        android:fillColor="#00E5D1" />

    <!-- Center node (middle - dark ring effect) -->
    <path
        android:pathData="M14,14 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
        android:fillColor="#0A1628" />

    <!-- Connection dots (4 cardinal points) -->
    <path
        android:pathData="M2,14 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#00E5D1"
        android:fillAlpha="0.85" />

    <path
        android:pathData="M26,14 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#00E5D1"
        android:fillAlpha="0.85" />

    <path
        android:pathData="M14,2 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#00E5D1"
        android:fillAlpha="0.85" />

    <path
        android:pathData="M14,26 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#00E5D1"
        android:fillAlpha="0.85" />

</vector>
